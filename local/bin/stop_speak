#!/usr/bin/env fish

# Signal the Kokoro TTS server (kokoro-server.py) on 127.0.0.1:5050 to stop
# whatever it's currently playing by sending the !!!STOP!!! interrupt.
#
#   stop_speak

printf '!!!STOP!!!' | command python3 -c 'import socket, sys
data = sys.stdin.buffer.read()
with socket.create_connection(("127.0.0.1", 5050)) as s:
    s.sendall(data)
    s.shutdown(socket.SHUT_WR)'
