#!/bin/bash
# Machine setup script for macOS using default Bash (3.2 compatible)
set -euo pipefail

DOTFILES_DIR="$HOME/.dotfiles"

# 0. Check if running the local cloned setup script.
# If not, clone the repository first and re-execute from the local copy.
RUNNING_LOCAL=0
if [ -n "${BASH_SOURCE[0]:-}" ]; then
    SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd 2>/dev/null || echo "")"
    if [ "$SCRIPT_DIR" = "$DOTFILES_DIR" ]; then
        RUNNING_LOCAL=1
    fi
fi

if [ "$RUNNING_LOCAL" -ne 1 ]; then
    if [ ! -d "$DOTFILES_DIR/.git" ]; then
        echo "📥 Cloning dotfiles repository..."
        git clone https://github.com/Jaya-Hoyt/.dotfiles.git "$DOTFILES_DIR"
    fi
    echo "🔄 Re-executing setup from local repository..."
    exec "$DOTFILES_DIR/setup_dotfiles"
fi

BASEDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Ensure local bin is in PATH for the duration of this script
export PATH="$HOME/.local/bin:$PATH"

echo "🔄 Updating submodules..."
git -C "$BASEDIR" submodule update --init --recursive

echo "📝 Creating local configuration files if missing..."
touch ~/.zshrc_local
touch ~/.bashrc_local
touch ~/.tmux.local.conf
mkdir -p ~/.config/fish
touch ~/.config/fish/config.local.fish
mkdir -p ~/.config/nvim/lua
touch ~/.config/nvim/lua/init_local.lua

if [ ! -f ~/.gitignore ]; then
    echo "⚙️  Configuring global git excludes..."
    git config --global core.excludesFile ~/.gitignore
fi

# 1. Install OS-specific package manager and dependencies
OS_TYPE="$(uname -s)"
if [ "$OS_TYPE" = "Darwin" ]; then
    if ! command -v brew >/dev/null 2>&1; then
        echo "🍺 Installing Homebrew..."
        NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    fi

    # Set up Homebrew environment for this script execution
    if [ -d "/opt/homebrew/bin" ]; then
        eval "$(/opt/homebrew/bin/brew shellenv)"
    elif [ -d "/usr/local/bin" ]; then
        eval "$(/usr/local/bin/brew shellenv)"
    fi

    # 2. Install Brewfile dependencies
    if [ -f "$BASEDIR/Brewfile" ]; then
        echo "📦 Installing Homebrew packages from Brewfile..."
        brew bundle --file="$BASEDIR/Brewfile"
    fi
elif [ "$OS_TYPE" = "Linux" ]; then
    if command -v apt-get >/dev/null 2>&1; then
        echo "🐧 Linux detected. Installing build dependencies..."
        if ! command -v bison >/dev/null 2>&1 || ! command -v yacc >/dev/null 2>&1; then
            sudo apt-get update
            sudo apt-get install -y bison byacc
        fi
    fi
fi


# 3. Install mise if missing
if ! command -v mise >/dev/null 2>&1; then
    echo "🛠️  Installing mise..."
    curl -fsSL https://mise.run | sh
fi

# 4. Run Dotbot linking
echo "🔗 Running Dotbot configuration link..."
"$BASEDIR/install"

# 4.5 Ensure ~/.ssh/scloud_config is generated and included in ~/.ssh/config
SSH_CONFIG="$HOME/.ssh/config"
INCLUDE_LINE="Include ~/.ssh/scloud_config"
SCLOUD_CONFIG_DEST="$HOME/.ssh/scloud_config"

RESOLVED_SCLOUD_HOST="${SCLOUD_HOST:-}"
if [ -z "$RESOLVED_SCLOUD_HOST" ] && command -v fish >/dev/null 2>&1; then
    RESOLVED_SCLOUD_HOST=$(fish -c 'echo $SCLOUD_HOST' 2>/dev/null)
fi

if [ -z "$RESOLVED_SCLOUD_HOST" ]; then
    if [ -t 0 ]; then
        echo "❓ SCLOUD_HOST environment variable is not set."
        read -p "👉 Enter your remote Cloudtop hostname (e.g. username.c.googlers.com): " RESOLVED_SCLOUD_HOST
        if [ -n "$RESOLVED_SCLOUD_HOST" ] && command -v fish >/dev/null 2>&1; then
            fish -c "set -Ux SCLOUD_HOST '$RESOLVED_SCLOUD_HOST'"
        fi
    else
        echo "⚠️ SCLOUD_HOST is not set and stdin is not a TTY. Skipping scloud_config generation."
    fi
fi

if [ -n "$RESOLVED_SCLOUD_HOST" ]; then
    echo "⚙️  Generating ~/.ssh/scloud_config..."
    mkdir -p "$HOME/.ssh"
    sed "s/{{SCLOUD_HOST}}/$RESOLVED_SCLOUD_HOST/g" "$BASEDIR/ssh_config.template" > "$SCLOUD_CONFIG_DEST"
    chmod 600 "$SCLOUD_CONFIG_DEST"
fi

mkdir -p "$HOME/.ssh"
touch "$SSH_CONFIG"
if ! grep -qF "$INCLUDE_LINE" "$SSH_CONFIG"; then
    echo "⚙️  Adding Include ~/.ssh/scloud_config to ~/.ssh/config..."
    TEMP_CONFIG=$(mktemp)
    echo "$INCLUDE_LINE" > "$TEMP_CONFIG"
    cat "$SSH_CONFIG" >> "$TEMP_CONFIG"
    mv "$TEMP_CONFIG" "$SSH_CONFIG"
fi



# 5. Install mise tools (non-interactive)
echo "📥 Installing tools configured in mise..."
mise install --yes

# 6. Install Tmux Plugin Manager (TPM)
if [ ! -d ~/.tmux/plugins/tpm ]; then
    echo "🔌 Installing Tmux Plugin Manager..."
    git clone https://github.com/tmux-plugins/tpm ~/.tmux/plugins/tpm
    ~/.tmux/plugins/tpm/scripts/install_plugins.sh
fi

if [ "$OS_TYPE" = "Darwin" ]; then
    # 7. Restore Keyboard Maestro Macros
    if [ -f "$BASEDIR/KeyboardMaestroMacros.kmsync" ]; then
        echo "🎹 Restoring Keyboard Maestro Macros..."
        killall "Keyboard Maestro" 2>/dev/null || true
        killall "Keyboard Maestro Engine" 2>/dev/null || true

        mkdir -p "$HOME/Library/Application Support/Keyboard Maestro"
        cp "$BASEDIR/KeyboardMaestroMacros.kmsync" "$HOME/Library/Application Support/Keyboard Maestro/Keyboard Maestro Macros.plist"

        if [ -d "/Applications/Keyboard Maestro.app" ]; then
            echo "🎹 Opening Keyboard Maestro to register configuration..."
            open -a "Keyboard Maestro"
        fi
    fi

    # 8. Open Karabiner Elements to initialize config
    if [ -d "/Applications/Karabiner-Elements.app" ]; then
        echo "⌨️  Opening Karabiner-Elements to register configuration..."
        open -a "Karabiner-Elements"
    fi
fi

echo "🎉 Dotfiles setup complete!"
